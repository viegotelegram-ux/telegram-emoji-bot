# Get this from @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Public HTTPS URL where this server is hosted (needed for webhook + Mini App)
# e.g. https://your-app.onrender.com or https://your-domain.com
PUBLIC_URL=https://your-domain.com

# Port the express server listens on
PORT=3000

# Set to "true" to use webhooks (recommended for production).
# Set to "false" to use long polling (fine for local dev/testing).
USE_WEBHOOK=false
